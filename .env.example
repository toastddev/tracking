# Server
PORT=3000

# Firestore credentials — pick ONE of the following options
# Option A: path to a service account JSON file on disk (standard Google SDK var)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# Option B: inline JSON of the service account (useful for containers/secret mgrs)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"..."}

# Optional: explicit project id (only needed if the SDK can't infer it)
# GOOGLE_CLOUD_PROJECT=my-gcp-project

# Admin dashboard auth — required for the /api/* routes the frontend calls.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
# Comma-separated origins allowed to call the admin API (CORS).
# Use "*" only in dev. In prod, list your dashboard origin(s).
ADMIN_CORS_ORIGINS=http://localhost:5173

# Public base URL of THIS tracking backend — used to render tracking links
# in the admin UI (e.g. https://tracker.example.com).
PUBLIC_TRACKING_BASE_URL=http://localhost:3000

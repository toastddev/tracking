{
  "name": "tracking-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "seed": "node --env-file=.env --import tsx seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "firebase-admin": "^13.0.2",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "tsx": "^4.19.2",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
